# Normalize line endings for all text files to LF in the repo,
# regardless of each platform's core.autocrlf setting.
* text=auto eol=lf

# Windows-specific scripts should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files should never be touched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
